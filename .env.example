# Required for real API mode. Include the backend API prefix.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Use "real" for backend integration and "mock" for empty/fallback development states.
NEXT_PUBLIC_API_MODE=real

# Required for production SEO, sitemap and canonical URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

NEXT_PUBLIC_DEFAULT_LOCALE=ru
NEXT_PUBLIC_SUPPORTED_LOCALES=ru,kk
NEXT_PUBLIC_ENABLE_WISHLIST=false
NEXT_PUBLIC_ENABLE_NEWSLETTER=false

# Optional public contact values. Leave empty until business confirms them.
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_CONTACT_INSTAGRAM=
NEXT_PUBLIC_CONTACT_ADDRESS=
